{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "allowJs": true,
    "checkJs": false,
    "lib": ["ES2022", "DOM"],
    "types": ["node", "vitest/globals"],
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": [
    "background.ts",
    "content/**/*.ts",
    "sidepanel/**/*.ts",
    "canvas/**/*.ts",
    "tests/**/*.ts",
    "vite.config.ts",
    "types/**/*.d.ts"
  ]
}
